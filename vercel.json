{
    "functions": {
        "api/*.php": {
            "runtime": "vercel-php@0.9.0"
        }
    },
    "routes": [
        {
            "src": "/src/assets/fonts/(.*)",
            "dest": "/src/assets/fonts/$1"
        },
             {
            "src": "/src/assets/videos/(.*)",
            "dest": "/src/assets/videos/$1"
        },
        {
            "src": "/src/assets/css/(.*)",
            "dest": "/src/assets/css/$1"
        },
        {
            "src": "/src/assets/js/(.*)",
            "dest": "/src/assets/js/$1"
        },
        {
            "src": "/src/assets/img/(.*)",
            "dest": "/src/assets/img/$1"
        },
        {
            "src": "/src/components/(.*)",
            "dest": "/src/components/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}
