{
    "functions": {
        "api/*.php": {
            "runtime": "vercel-php@0.9.0"
        }
    },
    "routes": [

        {
            "src": "/build/css/(.*)",
            "dest": "/build/css/$1"
        },
        {
            "src": "/build/js/(.*)",
            "dest": "/build/js/$1"
        },
        {
            "src": "/build/img/(.*)",
            "dest": "/build/img/$1"
        },
        {
            "src": "/src/components/(.*)",
            "dest": "/src/components/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}